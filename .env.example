# NeuralTrade Configuration
# Copy this to .env and fill in your values

# -- LLM Provider API Keys (at least one required) --
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# -- Default Model Configuration --
# Format: provider/model-name
# Examples: openai/gpt-4o, anthropic/claude-sonnet-4, google/gemini-2.0-flash
NEURALTRADE_DEFAULT_MODEL=openai/gpt-4o-mini
NEURALTRADE_REASONING_MODEL=openai/gpt-4o
NEURALTRADE_FAST_MODEL=openai/gpt-4o-mini

# -- Agent Model Overrides (optional) --
# Leave empty to use defaults
ANALYST_MODEL=
RESEARCHER_MODEL=
TRADER_MODEL=
RISK_MANAGER_MODEL=
PORTFOLIO_MANAGER_MODEL=

# -- Market Data --
ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=
CRYPTO_NEWS_API_KEY=

# -- Trading Settings --
INITIAL_CAPITAL=100000
MAX_POSITION_SIZE=0.25
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10
PAPER_TRADING=true

# -- Server --
NEURALTRADE_HOST=0.0.0.0
NEURALTRADE_PORT=8080
